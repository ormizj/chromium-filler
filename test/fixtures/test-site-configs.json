[
  {
    "id": "slow-boards",
    "name": "SlowBoards (test)",
    "urlPatterns": ["*://*/sites/slow-boards.html*", "file://*slow-boards.html*"],
    "waitFor": "#application-form",
    "waitTimeoutMs": 15000,
    "prep": [{ "action": "click", "selector": "#expand-description", "optional": true }],
    "extract": { "jobTitle": "#job-title", "jobDescription": "#job-description" },
    "successSelector": "#app-success",
    "autoDetect": true
  },
  {
    "id": "modal-lever",
    "name": "ModalLever (test)",
    "urlPatterns": ["*://*/sites/modal-lever.html*", "file://*modal-lever.html*"],
    "prep": [
      { "action": "click", "selector": "#apply-btn" },
      { "action": "waitFor", "selector": "#modal-form", "ms": 8000 },
      { "action": "click", "selector": "#add-resume", "optional": true }
    ],
    "extract": { "jobTitle": "#posting-title", "jobDescription": "#posting-body" },
    "cvUpload": "#resume-hidden",
    "successSelector": "#lever-success",
    "autoDetect": true
  },
  {
    "id": "cv-confirm",
    "name": "DialogATS (test)",
    "urlPatterns": ["*://*/sites/cv-confirm.html*", "file://*cv-confirm.html*"],
    "waitFor": "#application-form",
    "prep": [{ "action": "click", "selector": "#open-cv", "optional": true }],
    "extract": { "jobTitle": "#job-title", "jobDescription": "#job-description" },
    "cvUpload": "#cv-file",
    "submitCv": [{ "action": "click", "selector": "#cv-attach" }],
    "successSelector": "#dialog-success",
    "autoDetect": true
  },
  {
    "id": "redirect-board",
    "name": "MixedBoard (test)",
    "urlPatterns": ["*://*/sites/redirect-board.html*"],
    "extract": { "jobTitle": "#job-title", "jobDescription": "#job-description" },
    "redirect": {
      "beforeFollow": [{ "action": "click", "selector": "#save-job" }]
    },
    "successSelector": "#board-success",
    "autoDetect": true
  },
  {
    "id": "external-board",
    "name": "ExternalBoard (test)",
    "urlPatterns": ["*://*/sites/external-board.html*"],
    "extract": { "jobTitle": "#job-title", "jobDescription": "#job-description" },
    "redirect": {
      "applySelector": "#apply-external, #apply-js, #continue-link",
      "markerSelector": "#external-badge",
      "beforeFollow": [{ "action": "click", "selector": "#save-job" }]
    },
    "autoDetect": true
  },
  {
    "id": "quick-board",
    "name": "QuickBoard (test)",
    "urlPatterns": ["*://*/sites/quick-board.html*"],
    "extract": { "jobTitle": "#job-title", "jobDescription": "#job-description" },
    "redirect": { "quickApplySelector": "#application-form" },
    "successSelector": "#quick-success",
    "autoDetect": true
  },
  {
    "id": "listing-board",
    "name": "ListingBoard (test)",
    "urlPatterns": ["*://*/sites/listing-board.html*"],
    "extract": { "jobTitle": "#page-title", "jobDescription": "#page-blurb" },
    "successSelector": "#application-received",
    "autoDetect": true
  },
  {
    "id": "hidden-success",
    "name": "HiddenSuccess (test)",
    "urlPatterns": ["*://*/sites/hidden-success.html*"],
    "waitFor": "#application-form",
    "extract": { "jobTitle": "#job-title", "jobDescription": "#job-description" },
    "successSelector": "#late-success",
    "autoDetect": true
  },
  {
    "id": "chaos-form",
    "name": "ChaosForm (test)",
    "urlPatterns": ["*://*/sites/chaos-form.html*", "file://*chaos-form.html*"],
    "waitFor": "#chaos-form",
    "waitTimeoutMs": 15000,
    "prep": [{ "action": "click", "selector": "#next-btn", "optional": true }],
    "extract": { "jobTitle": "#role-title", "jobDescription": "#role-desc" },
    "successSelector": "#chaos-success",
    "autoDetect": true
  },
  {
    "id": "nav-thanks",
    "name": "NavATS confirmation (test)",
    "urlPatterns": ["*://127.0.0.1:5200/sites/thanks.html*"],
    "extract": {},
    "successSelector": "#thanks",
    "autoDetect": true
  }
]
